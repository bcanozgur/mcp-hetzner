# Hetzner Cloud API token (required for server/volume/firewall/network tools)
HCLOUD_TOKEN=your_hetzner_cloud_api_token_here

# Hetzner DNS API token (required only for DNS zone/record tools).
# This is a SEPARATE credential from HCLOUD_TOKEN — create one at
# https://dns.hetzner.com/settings/api-token
HETZNER_DNS_TOKEN=your_hetzner_dns_api_token_here
